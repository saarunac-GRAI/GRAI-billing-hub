# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth + Gmail API
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_USER=saarunac@gmail.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Yahoo IMAP
YAHOO_EMAIL=your-yahoo-email@yahoo.com
YAHOO_APP_PASSWORD=your-yahoo-app-password
YAHOO_DEFAULT_PROJECT_ID=your-personal-project-uuid
NEXT_PUBLIC_YAHOO_EMAIL=your-yahoo-email@yahoo.com

# n8n alert webhook secret
N8N_WEBHOOK_SECRET=your-random-secret-string

# Plaid (credit card transaction import)
# Sign up at https://dashboard.plaid.com
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox
NEXT_PUBLIC_PLAID_ENV=sandbox

# Web Push (VAPID) — generate with: node -e "require('web-push').generateVAPIDKeys()"
VAPID_EMAIL=mailto:your-email@gmail.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
NEXT_PUBLIC_VAPID_KEY=your-vapid-public-key
